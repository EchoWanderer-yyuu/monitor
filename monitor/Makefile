####### Compile

camerawidget.o: camerawidget.cpp camerawidget.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o camerawidget.o camerawidget.cpp

main.o: main.cpp mainwindow.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o main.o main.cpp

mainwindow.o: mainwindow.cpp mainwindow.h \
		ui_mainwindow.h \
		camerawidget.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o mainwindow.o mainwindow.cpp

moc_camerawidget.o: moc_camerawidget.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o moc_camerawidget.o moc_camerawidget.cpp

moc_mainwindow.o: moc_mainwindow.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o moc_mainwindow.o moc_mainwindow.cpp

####### Install

install_target: first FORCE
	@test -d $(INSTALL_ROOT)/opt/monitor/bin || mkdir -p $(INSTALL_ROOT)/opt/monitor/bin
	$(QINSTALL_PROGRAM) $(QMAKE_TARGET) $(INSTALL_ROOT)/opt/monitor/bin/$(QMAKE_TARGET)
	-$(STRIP) $(INSTALL_ROOT)/opt/monitor/bin/$(QMAKE_TARGET)

uninstall_target: FORCE
	-$(DEL_FILE) $(INSTALL_ROOT)/opt/monitor/bin/$(QMAKE_TARGET)
	-$(DEL_DIR) $(INSTALL_ROOT)/opt/monitor/bin/ 


install: install_target  FORCE

uninstall: uninstall_target  FORCE

